<Window x:Class="MeshhessenClient.PlotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:oxy="http://oxyplot.org/wpf"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{DynamicResource StrPlotWindowTitle}"
        Width="900" Height="600"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" MinWidth="180"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left panel ── -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Scrollable controls -->
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Nodes -->
                    <TextBlock Text="{DynamicResource StrPlotNodes}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ListBox x:Name="NodeListBox"
                             SelectionMode="Multiple"
                             MaxHeight="180"
                             Margin="0,0,0,10"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="OnSelectionChanged"/>

                    <!-- Metriken -->
                    <TextBlock Text="{DynamicResource StrPlotMetric}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ListBox x:Name="MetricListBox"
                             SelectionMode="Multiple"
                             Margin="0,0,0,10">
                        <ListBoxItem Tag="snr"          Content="SNR (dB)"/>
                        <ListBoxItem Tag="rssi"         Content="RSSI (dBm)"/>
                        <ListBoxItem Tag="battery"      Content="{DynamicResource StrPlotBattery}"/>
                        <ListBoxItem Tag="voltage"      Content="{DynamicResource StrPlotVoltage}"/>
                        <ListBoxItem Tag="channel_util" Content="Channel Util (%)"/>
                        <ListBoxItem Tag="air_tx_util"  Content="Air TX Util (%)"/>
                        <ListBoxItem Tag="hop_count"    Content="Hop Count"/>
                    </ListBox>

                    <!-- Zeitraum -->
                    <TextBlock Text="{DynamicResource StrPlotTimeRange}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <RadioButton x:Name="PlotRange7d"  Content="{DynamicResource StrPlot7d}"  GroupName="PlotRange" IsChecked="True"  Margin="0,0,0,4" Checked="OnPlotRangeChanged"/>
                    <RadioButton x:Name="PlotRange14d" Content="{DynamicResource StrPlot14d}" GroupName="PlotRange" Margin="0,0,0,4" Checked="OnPlotRangeChanged"/>
                    <RadioButton x:Name="PlotRange30d" Content="{DynamicResource StrPlot30d}" GroupName="PlotRange" Margin="0,0,0,4" Checked="OnPlotRangeChanged"/>
                    <RadioButton x:Name="PlotRangeAll" Content="{DynamicResource StrPlotAll}" GroupName="PlotRange" Margin="0,0,0,10" Checked="OnPlotRangeChanged"/>

                    <!-- Ansicht -->
                    <TextBlock Text="{DynamicResource StrPlotView}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <RadioButton x:Name="ViewRaw"    Content="{DynamicResource StrPlotRaw}"     GroupName="View" IsChecked="True" Margin="0,0,0,4" Checked="OnViewChanged"/>
                    <RadioButton x:Name="ViewAvg1h"  Content="{DynamicResource StrPlotMovAvg1h}"  GroupName="View" Margin="0,0,0,4" Checked="OnViewChanged"/>
                    <RadioButton x:Name="ViewAvg6h"  Content="{DynamicResource StrPlotMovAvg6h}"  GroupName="View" Margin="0,0,0,4" Checked="OnViewChanged"/>
                    <RadioButton x:Name="ViewAvg24h" Content="{DynamicResource StrPlotMovAvg24h}" GroupName="View" Margin="0,0,0,4" Checked="OnViewChanged"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Export pinned at bottom -->
            <Button Grid.Row="1" Content="{DynamicResource StrPlotExportPng}"
                    HorizontalAlignment="Stretch"
                    Padding="8,6"
                    Margin="0,8,0,0"
                    Click="ExportPng_Click"/>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

        <!-- ── Plot area ── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <oxy:PlotView Grid.Row="0" x:Name="Plot" Margin="0,8,8,0"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4,8,8">
                <TextBlock x:Name="StatusText" FontSize="11" Opacity="0.55" VerticalAlignment="Center"/>
                <Button Content="{DynamicResource StrPlotRefresh}" Padding="8,4" Margin="16,0,0,0" Click="Refresh_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
