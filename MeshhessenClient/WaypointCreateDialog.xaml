<Window x:Class="MeshhessenClient.WaypointCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Waypoint erstellen" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="0,0,0,8" MaxLength="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Beschreibung:" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="DescBox" Margin="0,0,0,8" MaxLength="100"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Icon (Emoji):" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="IconBox" Text="📍" Margin="0,0,0,8" MaxLength="2"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ablauf (h):" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="ExpiryBox" Width="60" Text="0"/>
            <TextBlock Text="  0 = kein Ablauf" VerticalAlignment="Center" FontSize="10" Foreground="Gray"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="CoordText" FontSize="10" Foreground="Gray"
                   Margin="0,0,0,8" TextWrapping="Wrap"/>

        <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="SendToMeshCheckBox" IsChecked="False" Margin="0,0,0,8"
                  Content="Im Mesh senden (an alle verbundenen Nodes)"/>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Erstellen" Width="90" Margin="0,0,8,0" Click="Create_Click" IsDefault="True"/>
            <Button Content="Abbrechen" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
