<Window x:Class="MeshhessenClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:MeshhessenClient.Converters"
        xmlns:helpers="clr-namespace:MeshhessenClient.Helpers"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        mc:Ignorable="d"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="pack://application:,,,/Resources/app.ico"
        Title="Meshhessen Client"
        Height="650"
        Width="1000"
        MinHeight="450"
        MinWidth="700">
    <Window.Resources>
        <converters:MqttIconConverter x:Key="MqttIconConverter"/>
        <converters:MqttTooltipConverter x:Key="MqttTooltipConverter"/>
        <converters:AlertBellIconConverter x:Key="AlertBellIconConverter"/>
        <converters:HexToColorConverter x:Key="HexToColorConverter"/>
        <converters:HexToAccentBrushConverter x:Key="HexToAccentBrushConverter"/>
        <converters:HexToTintBrushConverter x:Key="HexToTintBrushConverter"/>
        <converters:IsNotEmptyConverter x:Key="IsNotEmptyConverter"/>
        <converters:NoteToParenthesesConverter x:Key="NoteToParenthesesConverter"/>
        <converters:MessageDocumentConverter x:Key="MsgDocConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Alert Bell Overlay (Blinkt bei Notruf) -->
        <Border x:Name="AlertBellOverlay"
                Grid.RowSpan="5"
                BorderBrush="Red"
                BorderThickness="8"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="Red" ShadowDepth="0" BlurRadius="20" Opacity="0.8"/>
            </Border.Effect>
        </Border>

        <!-- Alert Notification Bar -->
        <Border x:Name="AlertNotificationBar"
                Grid.Row="0"
                Background="#FFCC0000"
                Padding="10,8"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="🚨"
                          FontSize="16"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <TextBlock x:Name="AlertNotificationText"
                          Grid.Column="1"
                          Text="{DynamicResource StrAlertReceived}"
                          Foreground="White"
                          FontWeight="Bold"
                          VerticalAlignment="Center"/>

                <Button x:Name="ShowOnMapButton"
                       Grid.Column="2"
                       Content="{DynamicResource StrGoToMap}"
                       Margin="10,0,10,0"
                       Padding="10,5"
                       Background="White"
                       Foreground="Black"
                       FontWeight="Bold"
                       Click="ShowOnMap_Click"
                       Visibility="Collapsed"/>

                <Button Grid.Column="3"
                       Content="✖"
                       Padding="8,2"
                       Background="Transparent"
                       Foreground="White"
                       BorderThickness="0"
                       FontWeight="Bold"
                       FontSize="14"
                       Click="CloseAlertNotification_Click"
                       Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Connection Controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Connection Type Radio Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                        <RadioButton x:Name="SerialRadioButton"
                                    Content="📟 Serial"
                                    GroupName="ConnectionType"
                                    IsChecked="True"
                                    Checked="ConnectionTypeRadio_Changed"
                                    Tag="Serial"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,5,0"
                                    FontSize="12"
                                    MinWidth="0"/>
                        <RadioButton x:Name="BluetoothRadioButton"
                                    Content="📡 Bluetooth"
                                    GroupName="ConnectionType"
                                    Checked="ConnectionTypeRadio_Changed"
                                    Tag="Bluetooth"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,5,0"
                                    FontSize="12"
                                    MinWidth="0"/>
                        <RadioButton x:Name="WifiRadioButton"
                                    Content="🌐 WiFi"
                                    GroupName="ConnectionType"
                                    Checked="ConnectionTypeRadio_Changed"
                                    Tag="Tcp"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,5,0"
                                    FontSize="12"
                                    MinWidth="0"/>
                    </StackPanel>

                    <!-- Serial Connection UI -->
                    <StackPanel x:Name="SerialConnectionPanel" Orientation="Horizontal" Visibility="Visible">
                        <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="PortComboBox"
                                 Width="120"
                                 VerticalAlignment="Center"
                                 SelectionChanged="PortComboBox_SelectionChanged"/>
                        <Button x:Name="RefreshPortsButton"
                               Content="🔄"
                               Margin="5,0,0,0"
                               Width="45"
                               ToolTip="{DynamicResource StrRefreshPorts}"
                               Click="RefreshPorts_Click"/>
                    </StackPanel>

                    <!-- Bluetooth Connection UI -->
                    <StackPanel x:Name="BluetoothConnectionPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource StrDevice}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="BluetoothDeviceComboBox"
                                 Width="170"
                                 VerticalAlignment="Center"
                                 DisplayMemberPath="DisplayName"/>
                        <Button x:Name="ScanBluetoothButton"
                               Content="🔍"
                               Margin="5,0,0,0"
                               Width="40"
                               ToolTip="{DynamicResource StrScanDevices}"
                               Click="ScanBluetooth_Click"/>
                    </StackPanel>

                    <!-- TCP Connection UI -->
                    <StackPanel x:Name="TcpConnectionPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource StrTcpHost}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="TcpHostTextBox"
                                Width="150"
                                VerticalAlignment="Center"
                                ui:ControlHelper.PlaceholderText="192.168.1.1"
                                Text="192.168.1.1"/>
                        <TextBlock Text="{DynamicResource StrTcpPort}" VerticalAlignment="Center" Margin="8,0,5,0"/>
                        <TextBox x:Name="TcpPortTextBox"
                                Width="90"
                                VerticalAlignment="Center"
                                Text="4403"/>
                    </StackPanel>

                    <Button x:Name="ConnectButton"
                           Content="{DynamicResource StrConnect}"
                           Margin="8,0,0,0"
                           Click="Connect_Click"/>
                    <TextBlock x:Name="StationNameLabel"
                               Text=""
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="Red"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Connection Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="OpenDmWindowButton"
                           Content="💬 DMs"
                           Margin="0,0,10,0"
                           Click="OpenDmWindow_Click"
                           ToolTip="{DynamicResource StrOpenDms}"/>
                    <Ellipse x:Name="StatusIndicator"
                            Width="12"
                            Height="12"
                            Fill="Gray"
                            Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText"
                              Text="{DynamicResource StrDisconnected}"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Global Signal & Health Status Strip -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                UseLayoutRounding="True"
                Padding="12,5">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- "Netz:" label -->
                <TextBlock Grid.Column="0" Text="{DynamicResource StrNetStatus}" FontSize="11" Opacity="0.6"
                           VerticalAlignment="Center" Margin="0,0,10,0" ToolTip="{DynamicResource StrNetTooltip}"/>

                <!-- Column: Wetter / Kurzzeit-SNR -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,6,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource StrHdrWeather}" FontSize="9" Opacity="0.55"
                               HorizontalAlignment="Center" Margin="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse x:Name="GlobalWeatherLed" Width="11" Height="11" Fill="#757575"
                                 Margin="0,0,2,0" SnapsToDevicePixels="True" VerticalAlignment="Center"
                                 ToolTip="{DynamicResource StrWeatherLedTooltip}"/>
                        <TextBlock x:Name="GlobalWeatherArrow" Text="" FontSize="11" VerticalAlignment="Center"
                                   ToolTip="{DynamicResource StrWeatherLedTooltip}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Column: LZ / Langzeit-Antenne -->
                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,0,6,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource StrHdrAntenna}" FontSize="9" Opacity="0.55"
                               HorizontalAlignment="Center" Margin="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse x:Name="GlobalAntennaLed" Width="11" Height="11" Fill="#757575"
                                 Margin="0,0,2,0" SnapsToDevicePixels="True" VerticalAlignment="Center"
                                 ToolTip="{DynamicResource StrAntennaLedTooltip}"/>
                        <TextBlock x:Name="GlobalAntennaArrow" Text="" FontSize="11" VerticalAlignment="Center"
                                   ToolTip="{DynamicResource StrAntennaLedTooltip}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Column: NB / Nachbarn -->
                <StackPanel Grid.Column="3" Orientation="Vertical" Margin="0,0,6,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource StrHdrNeighbor}" FontSize="9" Opacity="0.55"
                               HorizontalAlignment="Center" Margin="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse x:Name="GlobalNeighborLed" Width="11" Height="11" Fill="#757575"
                                 Margin="0,0,2,0" SnapsToDevicePixels="True" VerticalAlignment="Center"
                                 ToolTip="{DynamicResource StrNeighborLedTooltip}"/>
                        <TextBlock x:Name="GlobalNeighborArrow" Text="" FontSize="11" VerticalAlignment="Center"
                                   ToolTip="{DynamicResource StrNeighborLedTooltip}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Column: PS / Pfadstabilität -->
                <StackPanel Grid.Column="4" Orientation="Vertical" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource StrHdrPath}" FontSize="9" Opacity="0.55"
                               HorizontalAlignment="Center" Margin="0,0,0,1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse x:Name="GlobalPathLed" Width="11" Height="11" Fill="#757575"
                                 Margin="0,0,2,0" SnapsToDevicePixels="True" VerticalAlignment="Center"
                                 ToolTip="{DynamicResource StrPathLedTooltip}"/>
                        <TextBlock x:Name="GlobalPathArrow" Text="" FontSize="11" VerticalAlignment="Center"
                                   ToolTip="{DynamicResource StrPathLedTooltip}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Column="5" Width="1" Height="20"
                           Fill="{DynamicResource SystemControlForegroundBaseLowBrush}"
                           Margin="0,0,10,0" SnapsToDevicePixels="True" VerticalAlignment="Center"/>

                <!-- Column: Mesh Health -->
                <StackPanel Grid.Column="6" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource StrMeshHealthLabel}" FontSize="9" Opacity="0.55"
                               HorizontalAlignment="Center" Margin="0,0,0,1"
                               ToolTip="{DynamicResource StrMeshHealthTooltip}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse x:Name="GlobalMeshHealthLed" Width="11" Height="11" Fill="#757575"
                                 VerticalAlignment="Center" Margin="0,0,4,0" SnapsToDevicePixels="True"
                                 ToolTip="{DynamicResource StrMeshHealthTooltip}"/>
                        <TextBlock x:Name="GlobalMeshHealthText" Text="–" FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="GlobalRxTrendArrow" Text="" FontSize="11"
                                   VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <TabControl x:Name="MainTabs" Grid.Row="3" Margin="0">

            <!-- Messages Tab -->
            <TabItem Header="{DynamicResource StrTabMessages}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Message Filter -->
                    <Grid Grid.Row="0" Margin="10,10,10,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource StrFilterChannel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="MessageChannelFilterComboBox"
                                 Grid.Column="1"
                                 Width="200"
                                 VerticalAlignment="Center"
                                 SelectionChanged="MessageChannelFilter_Changed"
                                 DisplayMemberPath="Name"/>
                        <Image x:Name="mh_logo_wide_top" Grid.Column="2" Height="56" Width="286"
                               Source="/logo_mh_wide.jpg" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Message List – Chat Bubble Layout -->
                    <ListView x:Name="MessageListView"
                             Grid.Row="1"
                             Margin="4,5,4,10"
                             ContextMenuOpening="MessagesListView_ContextMenuOpening"
                             ScrollViewer.ScrollChanged="MessageListView_ScrollChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">

                        <!-- Remove default selection chrome; keep selection tracking for context menu -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="ItemBd" Background="Transparent" Padding="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource MsgHoverBg}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource MsgSelectedBg}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6,3,6,3">
                                    <!-- Outer bubble border — theme-aware bg, switches side for own messages -->
                                    <Border MaxWidth="560" CornerRadius="4,14,14,14"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="Background"    Value="{DynamicResource MsgBubbleOtherBg}"/>
                                                <Setter Property="BorderBrush"   Value="{DynamicResource MsgBubbleOtherBorder}"/>
                                                <Setter Property="CornerRadius"  Value="4,14,14,14"/>
                                                <Setter Property="Margin"        Value="0,0,80,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOwnMessage}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter Property="Background"    Value="{DynamicResource MsgBubbleSelfBg}"/>
                                                        <Setter Property="BorderBrush"   Value="{DynamicResource MsgBubbleSelfBorder}"/>
                                                        <Setter Property="CornerRadius"  Value="14,4,14,14"/>
                                                        <Setter Property="Margin"        Value="80,0,0,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <!-- Node-color tint + content -->
                                        <Grid>
                                            <!-- Full-bubble node color tint (only for incoming messages with a set color) -->
                                            <Border Background="{Binding SenderColorHex, Converter={StaticResource HexToTintBrushConverter}}"
                                                    CornerRadius="3,13,13,13">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOwnMessage}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <!-- Main bubble content -->
                                            <StackPanel Margin="10,7,10,7">

                                                <!-- ── Sender header: name · short · note ── -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOwnMessage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <!-- Sender name -->
                                                    <TextBlock Text="{Binding From}"
                                                               FontWeight="SemiBold" FontSize="11.5"
                                                               Foreground="{DynamicResource MsgSenderNameFg}"
                                                               VerticalAlignment="Center"/>
                                                    <!-- Short name in parentheses -->
                                                    <TextBlock FontSize="10.5"
                                                               Foreground="{DynamicResource MsgSubtleFg}"
                                                               Margin="5,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding SenderShortName, StringFormat='({0})'}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SenderShortName}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Note badge -->
                                                    <Border Margin="6,0,0,0" Padding="4,1,4,1"
                                                            CornerRadius="3"
                                                            BorderThickness="1"
                                                            BorderBrush="{DynamicResource MsgAlertFg}"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SenderNote}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding SenderNote}"
                                                                   FontSize="10" FontStyle="Italic"
                                                                   Foreground="{DynamicResource MsgAlertFg}"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- ── Reply quote block ── -->
                                                <Border Visibility="{Binding HasReply, Converter={StaticResource BoolToVis}}"
                                                        Background="#120078D4"
                                                        BorderBrush="#0078D4"
                                                        BorderThickness="3,0,0,0"
                                                        CornerRadius="0,3,3,0"
                                                        Padding="7,3,6,3"
                                                        Margin="0,0,0,5">
                                                    <TextBlock Text="{Binding ReplyQuoteText}"
                                                               Foreground="{DynamicResource MsgSubtleFg}"
                                                               FontStyle="Italic" FontSize="10.5"
                                                               TextWrapping="Wrap"/>
                                                </Border>

                                                <!-- ── Message text ── -->
                                                <RichTextBox helpers:RichTextBoxHelper.BoundDocument="{Binding Message, Converter={StaticResource MsgDocConverter}}"
                                                             IsReadOnly="True" BorderThickness="0"
                                                             Background="Transparent" Padding="0"
                                                             IsTabStop="False"
                                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                             IsDocumentEnabled="True"
                                                             ContextMenuService.IsEnabled="False"
                                                             FontSize="13"
                                                             Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

                                                <!-- ── Footer row ── -->
                                                <DockPanel Margin="0,5,0,0" LastChildFill="False">
                                                    <!-- Left: status indicators -->
                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                        <!-- Alert Bell -->
                                                        <TextBlock Text="🔔" FontSize="12"
                                                                   Foreground="{DynamicResource MsgAlertFg}"
                                                                   Margin="0,0,5,0" VerticalAlignment="Center"
                                                                   ToolTip="Alert Bell / SOS">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasAlertBell}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <!-- MQTT -->
                                                        <TextBlock FontSize="10.5" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource MsgMqttFg}"
                                                                   Margin="0,0,5,0" VerticalAlignment="Center"
                                                                   ToolTip="{DynamicResource StrMqttBubbleTooltip}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Setter Property="Text" Value="⚡ MQTT"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsViaMqtt}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <!-- Encrypted -->
                                                        <TextBlock Text="🔒" FontSize="10"
                                                                   Foreground="{DynamicResource MsgSubtleFg}"
                                                                   Margin="0,0,4,0" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEncrypted}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <!-- Right: reactions · hops · time · channel -->
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <emoji:TextBlock Text="{Binding ReactionsDisplay}" FontSize="12"
                                                                         ToolTip="{Binding ReactionsDisplay}"
                                                                         VerticalAlignment="Center" Margin="0,0,8,0">
                                                            <emoji:TextBlock.Style>
                                                                <Style TargetType="emoji:TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ReactionsDisplay}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </emoji:TextBlock.Style>
                                                        </emoji:TextBlock>
                                                        <TextBlock Text="{Binding HopCountDisplay}"
                                                                   FontSize="10" Foreground="{DynamicResource MsgSubtleFg}"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                                                   ToolTip="{DynamicResource StrRelayHopsTooltip}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasHopCount}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Time}"
                                                                   FontSize="10" Foreground="{DynamicResource MsgSubtleFg}"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding ChannelName}"
                                                                   FontSize="9.5" Foreground="{DynamicResource MsgSubtleFg}"
                                                                   VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ChannelName}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource StrCopyMessage}" Click="MessageContextMenu_CopyMessage_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource StrSendDm}" Click="MessageContextMenu_SendDm_Click"/>
                                <MenuItem Header="{DynamicResource StrNodeInfo}" Click="MessageContextMenu_NodeInfo_Click"/>
                                <MenuItem Header="{DynamicResource StrShowOnMap}" Click="MessageContextMenu_ShowOnMap_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource StrSetColor}">
                                    <MenuItem Tag="#00FF00" Click="MessageContextMenu_SetColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorGreen}" Foreground="#00FF00" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#0080FF" Click="MessageContextMenu_SetColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorBlue}" Foreground="#0080FF" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#FFFF00" Click="MessageContextMenu_SetColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorYellow}" Foreground="#FFFF00" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#FF8000" Click="MessageContextMenu_SetColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorOrange}" Foreground="#FF8000" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#8000FF" Click="MessageContextMenu_SetColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorPurple}" Foreground="#8000FF" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#804000" Click="MessageContextMenu_SetColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorBrown}" Foreground="#804000" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#FF00FF" Click="MessageContextMenu_SetColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorPink}" Foreground="#FF00FF" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#00FFFF" Click="MessageContextMenu_SetColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorCyan}" Foreground="#00FFFF" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource StrRemoveColor}" Click="MessageContextMenu_RemoveColor_Click"/>
                                </MenuItem>
                                <MenuItem Header="{DynamicResource StrEditNote}" Click="MessageContextMenu_EditNote_Click"/>
                                <Separator/>
                                <MenuItem x:Name="PinMsgMenuItem" Header="{DynamicResource StrPin}" Click="MessageContextMenu_Pin_Click"/>
                                <MenuItem x:Name="ShowPathMsgMenuItem" Header="{DynamicResource StrShowPath}" Click="MessageContextMenu_ShowPath_Click"/>
                                <MenuItem x:Name="HidePathMsgMenuItem" Header="{DynamicResource StrHidePath}" Click="MessageContextMenu_HidePath_Click" Visibility="Collapsed"/>
                                <MenuItem Header="{DynamicResource StrTraceroute}" Click="MessageContextMenu_Traceroute_Click"/>
                                <MenuItem Header="{DynamicResource StrTelemetry}" Click="MessageContextMenu_Telemetry_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource StrReact}" Click="MessageContextMenu_React_Click"/>
                                <MenuItem Header="{DynamicResource StrReplyMessage}" Click="MessageContextMenu_Reply_Click"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>

                    <!-- Send Message -->
                    <StackPanel Grid.Row="2">
                        <!-- Reply indicator bar -->
                        <Border x:Name="ReplyIndicatorPanel"
                                Visibility="Collapsed"
                                Background="#150078D4"
                                BorderBrush="#0078D4"
                                BorderThickness="0,2,0,0"
                                Padding="10,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ReplyIndicatorText"
                                           Grid.Column="0"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                                           FontStyle="Italic"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="1"
                                        Content="{DynamicResource StrCancelReply}"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        Click="CancelReply_Click"
                                        Background="Transparent"
                                        FontSize="11"/>
                            </Grid>
                        </Border>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Channel Selection -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="{DynamicResource StrChannelLabel}" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <ComboBox x:Name="ActiveChannelComboBox"
                                     Width="150"
                                     VerticalAlignment="Center"
                                     SelectionChanged="ActiveChannelComboBox_SelectionChanged"
                                     DisplayMemberPath="Name"
                                     IsEnabled="False"/>
                        </StackPanel>

                        <TextBox x:Name="MessageTextBox"
                                Grid.Column="1"
                                ui:ControlHelper.PlaceholderText="{DynamicResource StrMessagePlaceholder}"
                                VerticalContentAlignment="Center"
                                Padding="10"
                                MaxLength="200"
                                KeyDown="MessageTextBox_KeyDown"/>

                        <Button x:Name="AlertBellButton"
                               Grid.Column="2"
                               Content="🚨 SOS"
                               Width="80"
                               Margin="10,0,0,0"
                               Background="#FFCC0000"
                               Foreground="White"
                               FontWeight="Bold"
                               ToolTip="{DynamicResource StrSosTooltip}"
                               Click="AlertBell_Click"/>

                        <Button x:Name="SendButton"
                               Grid.Column="3"
                               Content="{DynamicResource StrSend}"
                               Width="100"
                               Margin="10,0,0,0"
                               Click="Send_Click"/>
                    </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Nodes Tab -->
            <TabItem Header="{DynamicResource StrTabNodes}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Quick Filter -->
                    <TextBox x:Name="NodeFilterTextBox"
                             Grid.Row="0"
                             Margin="0,0,0,6"
                             TextChanged="NodeFilterTextBox_TextChanged"
                             Tag="🔍 Filter nach Name, ID, SNR, Batterie..."/>

                    <ListView x:Name="NodesListView" Grid.Row="1">
                        <ListView.View>
                            <GridView x:Name="NodesGridView">
                                <GridViewColumn Width="30">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="🎨"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="16" Height="16"
                                                    BorderBrush="Gray"
                                                    BorderThickness="1"
                                                    Background="{Binding ColorHex, Converter={StaticResource HexToColorConverter}}"
                                                    Visibility="{Binding ColorHex, Converter={StaticResource IsNotEmptyConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="150">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="Name" Click="NodeColumnHeader_Click" Tag="Name"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="Name"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Width="80">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="{DynamicResource StrColShort}" Click="NodeColumnHeader_Click" Tag="ShortName"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="ShortName"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Width="120">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="ID" Click="NodeColumnHeader_Click" Tag="Id"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="Id"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Width="100">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="{DynamicResource StrColDistance}" Click="NodeColumnHeader_Click" Tag="Distance"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="Distance"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Width="80">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="SNR" Click="NodeColumnHeader_Click" Tag="Snr"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="Snr"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Width="80">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="RSSI" Click="NodeColumnHeader_Click" Tag="Rssi"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="Rssi"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Width="80">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="{DynamicResource StrColBattery}" Click="NodeColumnHeader_Click" Tag="Battery"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="Battery"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Width="150">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="{DynamicResource StrColLastSeen}" Click="NodeColumnHeader_Click" Tag="LastSeen"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.DisplayMemberBinding>
                                        <Binding Path="LastSeen"/>
                                    </GridViewColumn.DisplayMemberBinding>
                                </GridViewColumn>
                                <GridViewColumn Width="35" DisplayMemberBinding="{Binding PkiKeyIcon}">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="🔑" ToolTip="PKI Public Key bekannt"/>
                                    </GridViewColumn.Header>
                                </GridViewColumn>
                                <GridViewColumn Width="56">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader ToolTip="Signal-Indikatoren: SNR-Qualität | SNR-Trend | Batterie&#xa;Grün=gut, Gelb=mittel, Rot=schlecht, Grau/leer=keine Daten"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                        UseLayoutRounding="True">
                                                <Ellipse Width="10" Height="10" Margin="1,0"
                                                         SnapsToDevicePixels="True"
                                                         Fill="{Binding SignalQualityColor, Converter={StaticResource HexToColorConverter}}"
                                                         ToolTip="{DynamicResource StrNodeSnrQualityTooltip}"/>
                                                <Ellipse Width="10" Height="10" Margin="1,0"
                                                         SnapsToDevicePixels="True"
                                                         Fill="{Binding SignalTrendColor, Converter={StaticResource HexToColorConverter}}"
                                                         ToolTip="{DynamicResource StrNodeSnrTrendTooltip}"/>
                                                <Ellipse Width="10" Height="10" Margin="1,0"
                                                         SnapsToDevicePixels="True"
                                                         Fill="{Binding BatteryStatusColor, Converter={StaticResource HexToColorConverter}}"
                                                         ToolTip="{DynamicResource StrNodeBatteryTooltip}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource StrSendDm}" Click="SendDmToNode_Click"/>
                                <MenuItem Header="{DynamicResource StrNodeInfo}" Click="NodeContextMenu_NodeInfo_Click"/>
                                <MenuItem Header="{DynamicResource StrShowOnMap}" Click="NodeContextMenu_ShowOnMap_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource StrSetColor}">
                                    <MenuItem Tag="#00FF00" Click="SetNodeColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorGreen}" Foreground="#00FF00" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#0080FF" Click="SetNodeColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorBlue}" Foreground="#0080FF" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#FFFF00" Click="SetNodeColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorYellow}" Foreground="#FFFF00" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#FF8000" Click="SetNodeColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorOrange}" Foreground="#FF8000" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#8000FF" Click="SetNodeColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorPurple}" Foreground="#8000FF" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#804000" Click="SetNodeColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorBrown}" Foreground="#804000" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#FF00FF" Click="SetNodeColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorPink}" Foreground="#FF00FF" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Tag="#00FFFF" Click="SetNodeColor_Click">
                                        <MenuItem.Header>
                                            <TextBlock Text="{DynamicResource StrColorCyan}" Foreground="#00FFFF" FontWeight="Bold"/>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource StrRemoveColor}" Click="RemoveNodeColor_Click"/>
                                </MenuItem>
                                <MenuItem Header="{DynamicResource StrEditNote}" Click="EditNodeNote_Click"/>
                                <Separator/>
                                <MenuItem x:Name="PinNodeMenuItem" Header="{DynamicResource StrPin}" Click="NodeContextMenu_Pin_Click"/>
                                <MenuItem x:Name="ShowPathNodeMenuItem" Header="{DynamicResource StrShowPath}" Click="NodeContextMenu_ShowPath_Click"/>
                                <MenuItem x:Name="HidePathMenuItem" Header="{DynamicResource StrHidePath}" Click="NodeContextMenu_HidePath_Click" Visibility="Collapsed"/>
                                <MenuItem Header="{DynamicResource StrTraceroute}" Click="NodeContextMenu_Traceroute_Click"/>
                                <MenuItem Header="{DynamicResource StrTelemetry}" Click="NodeContextMenu_Telemetry_Click"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- Channels Tab -->
            <TabItem Header="{DynamicResource StrTabChannels}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView x:Name="ChannelsListView" Grid.Row="0">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource StrCopyPsk}" Click="ChannelContextMenu_CopyPsk_Click"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Index" Width="60" DisplayMemberBinding="{Binding Index}"/>
                                <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="PSK" Width="300" DisplayMemberBinding="{Binding Psk}"/>
                                <GridViewColumn Header="Role" Width="100" DisplayMemberBinding="{Binding Role}"/>
                                <GridViewColumn Header="{DynamicResource StrMsgDbClearSelectedChannel}" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{DynamicResource StrMsgDbClearBtn}"
                                                    Tag="{Binding}"
                                                    Click="ClearSelectedChannelDb_Click"
                                                    Padding="4,2" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="{DynamicResource StrAddChannel}" Margin="0,0,10,0" Click="AddChannel_Click"/>
                        <Button Content="{DynamicResource StrDeleteChannel}" Margin="0,0,10,0" Click="DeleteChannel_Click"/>
                        <Button Content="{DynamicResource StrBrowseChannels}" Margin="0,0,10,0" Click="BrowseChannels_Click"/>
                        <Button x:Name="MeshHessenButton" Content="{DynamicResource StrMeshHessenChannel}"
                                Margin="0,0,10,0" Click="AddMeshHessenChannel_Click"
                                Background="#FF2E7D32" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="{DynamicResource StrTabSettings}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="290"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== Linke Spalte: Einstellungen ===== -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20,20,10,20">

                            <!-- a) Sprache -->
                            <GroupBox Header="Sprache / Language" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{DynamicResource StrLanguage}" Width="120" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="LanguageComboBox" Width="150" SelectionChanged="LanguageComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Deutsch" Tag="de"/>
                                            <ComboBoxItem Content="English" Tag="en"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <!-- b) Darstellung -->
                            <GroupBox Header="{DynamicResource StrAppearance}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="{DynamicResource StrStationName}" Width="120" VerticalAlignment="Center"/>
                                        <TextBox x:Name="StationNameTextBox" Width="200"/>
                                    </StackPanel>
                                    <TextBlock Text="{DynamicResource StrStationNameHint}"
                                              FontStyle="Italic" Foreground="Gray" FontSize="11" Margin="0,0,0,10"/>
                                    <CheckBox x:Name="DarkModeCheckBox"
                                             Content="{DynamicResource StrDarkMode}"
                                             IsChecked="False"
                                             Checked="DarkMode_Changed"
                                             Unchecked="DarkMode_Changed"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- c) Alert Bell -->
                            <GroupBox Header="{DynamicResource StrNotifications}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="AlertBellSoundCheckBox"
                                             Content="{DynamicResource StrAlertBellSound}"
                                             Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource StrAlertBellSoundHint}"
                                              FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" FontSize="11"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- d) Karte / Tiles -->
                            <GroupBox Header="{DynamicResource StrMapGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">

                                    <!-- Kartenstil -->
                                    <TextBlock Text="{DynamicResource StrMapSource}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="MapSourceComboBox"
                                             Width="250" HorizontalAlignment="Left" Margin="0,0,0,14"
                                             SelectionChanged="MapSourceComboBox_SelectionChanged">
                                        <ComboBoxItem Content="OpenStreetMap Standard" Tag="osm"/>
                                        <ComboBoxItem Content="OpenTopoMap" Tag="osmtopo"/>
                                        <ComboBoxItem Content="OpenStreetMap Dark" Tag="osmdark"/>
                                    </ComboBox>
                                    <TextBlock x:Name="MapSourceLockedHint"
                                              Text="{DynamicResource StrMapModeOnlineOsmSourceLocked}"
                                              FontSize="11" FontStyle="Italic" Foreground="Gray"
                                              Margin="0,-10,0,10" Visibility="Collapsed"/>

                                    <!-- Karten-Modus -->
                                    <TextBlock Text="{DynamicResource StrMapMode}" Margin="0,0,0,6" FontWeight="SemiBold"/>

                                    <!-- Offline -->
                                    <RadioButton x:Name="MapModeOfflineRadio" GroupName="MapMode"
                                                Content="{DynamicResource StrMapModeOffline}"
                                                Margin="0,0,0,2" Checked="MapModeRadio_Changed"/>
                                    <TextBlock Text="{DynamicResource StrMapModeOfflineDesc}"
                                              FontSize="11" Foreground="Gray" FontStyle="Italic"
                                              TextWrapping="Wrap" Margin="20,0,0,8"/>

                                    <!-- Online Meshhessen -->
                                    <RadioButton x:Name="MapModeOnlineOwnRadio" GroupName="MapMode"
                                                Content="{DynamicResource StrMapModeOnlineOwn}"
                                                Margin="0,0,0,2" Checked="MapModeRadio_Changed"/>
                                    <TextBlock Text="{DynamicResource StrMapModeOnlineOwnDesc}"
                                              FontSize="11" Foreground="Gray" FontStyle="Italic"
                                              TextWrapping="Wrap" Margin="20,0,0,8"/>

                                    <!-- Online OSM -->
                                    <RadioButton x:Name="MapModeOnlineOsmRadio" GroupName="MapMode"
                                                Content="{DynamicResource StrMapModeOnlineOsm}"
                                                Margin="0,0,0,2" Checked="MapModeRadio_Changed"/>
                                    <Border x:Name="OsmWarnBorder"
                                           Margin="20,2,0,10" Padding="8,6"
                                           Background="#FFF8E1" BorderBrush="#FFB300" BorderThickness="1"
                                           CornerRadius="3" Visibility="Collapsed">
                                        <TextBlock Text="{DynamicResource StrMapModeOnlineOsmWarn}"
                                                  FontSize="11" TextWrapping="Wrap" Foreground="#7B4700"/>
                                    </Border>

                                    <!-- Tile-Server URL (ausgeblendet im OSM-Online-Modus) -->
                                    <StackPanel x:Name="TileServerPanel">
                                        <TextBlock Text="{DynamicResource StrTileServerUrl}" Margin="0,4,0,4"/>
                                        <TextBox x:Name="TileServerUrlTextBox" HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                                        <TextBlock Text="{DynamicResource StrTileServerUrlHint}"
                                                  FontStyle="Italic" Foreground="Gray" FontSize="11" Margin="0,0,0,10"/>
                                    </StackPanel>

                                    <!-- Download/Import (nur im Offline-Modus) -->
                                    <StackPanel x:Name="TileDownloadPanel">
                                        <Button Content="{DynamicResource StrDownloadTiles}" Width="200" HorizontalAlignment="Left"
                                               Margin="0,0,0,6" Click="DownloadTiles_Click"/>
                                        <Button Content="{DynamicResource StrImportTilesZip}" Width="200" HorizontalAlignment="Left"
                                               Click="ImportTilesFromZip_Click"/>
                                    </StackPanel>

                                </StackPanel>
                            </GroupBox>

                            <!-- e) Telemetrie-Datenbank -->
                            <GroupBox Header="{DynamicResource StrTelemetryDbGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{DynamicResource StrRetentionLabel}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="TelemetryRetentionComboBox" Width="200" HorizontalAlignment="Left">
                                        <ComboBoxItem Tag="30"  Content="{DynamicResource StrRetention30}"/>
                                        <ComboBoxItem Tag="90"  Content="{DynamicResource StrRetention90}" IsSelected="True"/>
                                        <ComboBoxItem Tag="365" Content="{DynamicResource StrRetention365}"/>
                                        <ComboBoxItem Tag="0"   Content="{DynamicResource StrRetentionUnlimited}"/>
                                    </ComboBox>
                                </StackPanel>
                            </GroupBox>

                            <!-- f) Node Public-Keys (PKI) -->
                            <GroupBox Header="{DynamicResource StrNodeKeyGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <TextBlock Text="{DynamicResource StrNodeKeyHint}"
                                              FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,8"/>
                                    <RadioButton x:Name="PskWarnRadio"
                                                Content="{DynamicResource StrPskWarn}"
                                                GroupName="PskAction" Margin="0,0,0,4"/>
                                    <RadioButton x:Name="PskOverwriteRadio"
                                                Content="{DynamicResource StrPskOverwrite}"
                                                GroupName="PskAction" IsChecked="True" Margin="0,0,0,4"/>
                                    <RadioButton x:Name="PskAskRadio"
                                                Content="{DynamicResource StrPskAsk}"
                                                GroupName="PskAction"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- g) Signalanalyse-Fenster -->
                            <GroupBox Header="{DynamicResource StrSignalAnalysisGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <TextBlock FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap"
                                               FontSize="11" Margin="0,0,0,8"
                                               Text="{DynamicResource StrSignalAnalysisHint}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="28"/>
                                            <RowDefinition Height="28"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource StrSignalWeatherHours}" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBox  Grid.Row="0" Grid.Column="1" x:Name="WeatherHoursBox" Margin="0,2,8,2" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource StrSignalWeatherUnit}" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource StrSignalAntennasDays}" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBox  Grid.Row="1" Grid.Column="1" x:Name="AntennaDaysBox" Margin="0,2,8,2" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource StrSignalAntennaUnit}" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            <!-- h) Standort-Logging -->
                            <GroupBox Header="{DynamicResource StrLocationLoggingGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="EnableLocationLoggingCheckBox"
                                             Content="{DynamicResource StrLocationLogging}"
                                             Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource StrLocationLoggingHint}"
                                              FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" FontSize="11"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- h2) Positionsverlauf -->
                            <GroupBox Header="{DynamicResource StrPositionHistoryGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <TextBlock FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,8"
                                               Text="{DynamicResource StrPositionHistoryHint}"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource StrPositionHistoryShow}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                                        <ComboBox x:Name="PositionHistoryComboBox" Width="160" FontSize="11">
                                            <ComboBoxItem Content="{DynamicResource StrPosHistory6h}"        Tag="6"/>
                                            <ComboBoxItem Content="{DynamicResource StrPosHistory24h}"       Tag="24"  IsSelected="True"/>
                                            <ComboBoxItem Content="{DynamicResource StrPosHistory7d}"        Tag="168"/>
                                            <ComboBoxItem Content="{DynamicResource StrPosHistory30d}"       Tag="720"/>
                                            <ComboBoxItem Content="{DynamicResource StrPosHistoryUnlimited}" Tag="0"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <!-- h3) Zeitsynchronisation -->
                            <GroupBox Header="{DynamicResource StrTimeSyncGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="AutoTimeSyncCheckBox" IsChecked="True" Margin="0,0,0,6"
                                              Content="{DynamicResource StrAutoTimeSyncLabel}"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                                        <TextBlock Text="{DynamicResource StrTimeSyncDriftLabel}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                                        <TextBox x:Name="TimeSyncDriftBox" Width="60" Text="300" FontSize="11"/>
                                        <TextBlock Text="{DynamicResource StrTimeSyncDriftZero}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="10" Foreground="Gray"/>
                                    </StackPanel>
                                    <Button Content="{DynamicResource StrTimeSyncNow}" HorizontalAlignment="Left"
                                            Padding="8,3" FontSize="11"
                                            Click="TimeSyncManual_Click"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- f) Verschlüsselte Nachrichten -->
                            <GroupBox Header="{DynamicResource StrMessagesGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="ShowEncryptedMessagesCheckBox"
                                             Content="{DynamicResource StrShowEncrypted}"
                                             IsChecked="True"/>
                                    <TextBlock Text="{DynamicResource StrShowEncryptedHint}"
                                              FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Nachrichten-Datenbank -->
                            <GroupBox Header="{DynamicResource StrMsgDbGroup}" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="EnableMessageDbCheckBox"
                                             Content="{DynamicResource StrMsgDbEnable}"
                                             Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource StrMsgDbEnableHint}"
                                              FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap"
                                              FontSize="11" Margin="0,0,0,10"/>

                                    <TextBlock Text="{DynamicResource StrMsgDbRetention}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="MessageDbRetentionComboBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,12">
                                        <ComboBoxItem Tag="30"  Content="{DynamicResource StrRetention30}"/>
                                        <ComboBoxItem Tag="90"  Content="{DynamicResource StrRetention90}" IsSelected="True"/>
                                        <ComboBoxItem Tag="365" Content="{DynamicResource StrRetention365}"/>
                                        <ComboBoxItem Tag="0"   Content="{DynamicResource StrRetentionUnlimited}"/>
                                    </ComboBox>

                                    <Separator Margin="0,4,0,8"/>

                                    <TextBlock Text="{DynamicResource StrMsgDbClearHint}"
                                              FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap"
                                              FontSize="11" Margin="0,0,0,6"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="{DynamicResource StrMsgDbClearChannels}"
                                               Click="ClearChannelMessages_Click"
                                               Margin="0,0,8,0" Padding="8,3"/>
                                        <ComboBox x:Name="ClearChannelAgeComboBox" Width="130">
                                            <ComboBoxItem Tag="0"   Content="{DynamicResource StrMsgDbClearAll}" IsSelected="True"/>
                                            <ComboBoxItem Tag="30"  Content="{DynamicResource StrMsgDbClearOlder30}"/>
                                            <ComboBoxItem Tag="90"  Content="{DynamicResource StrMsgDbClearOlder90}"/>
                                            <ComboBoxItem Tag="365" Content="{DynamicResource StrMsgDbClearOlder365}"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <Button Content="{DynamicResource StrMsgDbClearDms}"
                                           Click="ClearDmMessages_Click"
                                           HorizontalAlignment="Left" Padding="8,3"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- g) Debug -->
                            <GroupBox Header="Debug" Margin="0,0,0,16">
                                <StackPanel Margin="10">
                                    <CheckBox x:Name="DebugMessagesCheckBox"
                                             Content="{DynamicResource StrDebugMessages}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="DebugSerialCheckBox"
                                             Content="{DynamicResource StrDebugSerial}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="DebugDeviceCheckBox"
                                             Content="{DynamicResource StrDebugDevice}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="DebugBluetoothCheckBox"
                                             Content="{DynamicResource StrDebugBluetooth}"/>
                                </StackPanel>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Fixed save button below scroll area -->
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="20,10">
                        <Button Content="{DynamicResource StrSaveSettings}"
                               Width="200" HorizontalAlignment="Left"
                               Click="SaveSettings_Click"/>
                    </Border>
                    </Grid>

                    <!-- ===== Rechte Spalte: Node-Konfig + Geräteinfo ===== -->
                    <Border Grid.Column="1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,20,16,20">

                                <!-- Node-Konfiguration -->
                                <GroupBox Header="{DynamicResource StrNodeConfigGroup}" Margin="0,0,0,16">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="{DynamicResource StrNodeConfigHint}"
                                                  FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap"
                                                  FontSize="11" Margin="0,0,0,10"/>
                                        <Button x:Name="NodeConfigButton" Content="{DynamicResource StrNodeConfig}"
                                               IsEnabled="False" Click="NodeConfig_Click"/>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Geräteinfo (nur Anzeige) -->
                                <GroupBox Header="{DynamicResource StrDeviceInfoGroup}">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="{DynamicResource StrDeviceName}" FontSize="11" Foreground="Gray" Margin="0,4,0,1"/>
                                        <TextBlock x:Name="NodeInfoLongNameText" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,6"/>

                                        <TextBlock Text="{DynamicResource StrDeviceShortName}" FontSize="11" Foreground="Gray" Margin="0,0,0,1"/>
                                        <TextBlock x:Name="NodeInfoShortNameText" FontWeight="SemiBold" Margin="0,0,0,6"/>

                                        <TextBlock Text="{DynamicResource StrDeviceHardware}" FontSize="11" Foreground="Gray" Margin="0,0,0,1"/>
                                        <TextBlock x:Name="HardwareModelText" TextWrapping="Wrap" Margin="0,0,0,6"/>

                                        <TextBlock Text="{DynamicResource StrDeviceFirmware}" FontSize="11" Foreground="Gray" Margin="0,0,0,1"/>
                                        <TextBlock x:Name="FirmwareVersionText" Margin="0,0,0,6"/>

                                        <TextBlock Text="{DynamicResource StrDeviceRegion}" FontSize="11" Foreground="Gray" Margin="0,0,0,1"/>
                                        <TextBlock x:Name="NodeInfoRegionText" Margin="0,0,0,6"/>

                                        <TextBlock Text="{DynamicResource StrDevicePreset}" FontSize="11" Foreground="Gray" Margin="0,0,0,1"/>
                                        <TextBlock x:Name="NodeInfoPresetText"/>
                                    </StackPanel>
                                </GroupBox>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Karte Tab -->
            <TabItem Header="{DynamicResource StrTabMap}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="10,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="+" Width="32" Height="32" Margin="0,0,4,0"
                                    Click="MapZoomIn_Click" ToolTip="Zoom In"/>
                            <Button Content="-" Width="32" Height="32" Margin="0,0,10,0"
                                    Click="MapZoomOut_Click" ToolTip="Zoom Out"/>
                            <Button Content="{DynamicResource StrLoadTraceroute}" Height="28" Margin="0,0,6,0"
                                    Padding="8,2"
                                    Click="MapLoadTraceroute_Click"
                                    ToolTip="{DynamicResource StrLoadTracerouteTooltip}"/>
                            <ComboBox x:Name="TracerouteAgeFilterCombo" Height="28" Width="70"
                                      Margin="0,0,4,0" ToolTip="{DynamicResource StrTracerouteDbTimeTooltip}">
                                <ComboBoxItem Content="3d"  Tag="3"   />
                                <ComboBoxItem Content="7d"  Tag="7"   IsSelected="True"/>
                                <ComboBoxItem Content="14d" Tag="14"  />
                                <ComboBoxItem Content="30d" Tag="30"  />
                                <ComboBoxItem Content="90d" Tag="90"  />
                                <ComboBoxItem Content="{DynamicResource StrAllTimeRange}" Tag="0"  />
                            </ComboBox>
                            <Button Content="{DynamicResource StrLoadFromDb}" Height="28" Padding="8,2" Margin="0,0,6,0"
                                    Click="MapLoadTracerouteFromDb_Click"
                                    ToolTip="{DynamicResource StrLoadFromDbTooltip}"/>
                            <CheckBox x:Name="TracerouteDedupeCheckBox" VerticalAlignment="Center"
                                      IsChecked="True" Margin="0,0,6,0"
                                      ToolTip="{DynamicResource StrDedupeTooltip}">
                                <TextBlock Text="Dedupe" FontSize="11"/>
                            </CheckBox>
                            <Button Content="{DynamicResource StrRemoveAllTraceroutes}" Height="28" Padding="8,2" Margin="0,0,0,0"
                                    Click="ClearAllTraceroutes_Click"
                                    ToolTip="{DynamicResource StrRemoveAllTooltip}"/>
                        </StackPanel>
                        <TextBlock x:Name="MapStatusText" Grid.Column="1" VerticalAlignment="Center" Foreground="Gray" FontStyle="Italic"/>
                    </Grid>
                    <Grid Grid.Row="1">
                        <mapsui:MapControl x:Name="MapControl"/>

                        <!-- Traceroute Legend (top-left overlay) -->
                        <Border x:Name="TracerouteLegend"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="8,8,0,0"
                                Background="#CC1E1E1E"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="8,6"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="📡 Traceroutes" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#BBDDDDDD" Margin="0,0,0,4"/>
                                <ItemsControl x:Name="TracerouteLegendItems"/>
                            </StackPanel>
                        </Border>

                        <!-- Map Line Types Legend (top-right overlay) -->
                    <Border x:Name="MapLegendBorder" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,8,8,0" Padding="8,6" CornerRadius="6"
                            Background="#CC000000" BorderBrush="#44FFFFFF" BorderThickness="1"
                            Panel.ZIndex="10">
                        <StackPanel>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="✕" Width="18" Height="18"
                                        Padding="0" FontSize="10" Margin="6,0,0,0"
                                        Click="MapLegendClose_Click"/>
                                <TextBlock Text="{DynamicResource StrLegendTitle}"
                                           FontWeight="Bold" Foreground="White" FontSize="11"/>
                            </DockPanel>
                            <!-- Normal hop line: solid gray -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Line X1="0" Y1="5" X2="30" Y2="5" Stroke="Gray" StrokeThickness="2" Width="30" Height="10"/>
                                <TextBlock Text="{DynamicResource StrLegendNormalHop}" Foreground="White" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- MQTT dashed: yellow -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Line X1="0" Y1="5" X2="30" Y2="5" Stroke="Yellow" StrokeThickness="2"
                                      StrokeDashArray="3,2" Width="30" Height="10"/>
                                <TextBlock Text="{DynamicResource StrLegendMqttHop}" Foreground="White" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Unknown dashed: dashed gray -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Line X1="0" Y1="5" X2="30" Y2="5" Stroke="Gray" StrokeThickness="2"
                                      StrokeDashArray="4,3" Width="30" Height="10"/>
                                <TextBlock Text="{DynamicResource StrLegendUnknownHop}" Foreground="White" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- SNR click hint -->
                            <TextBlock Text="{DynamicResource StrLegendSnrHint}" Foreground="#AAAAAA" FontSize="9"
                                       Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="160"/>
                        </StackPanel>
                    </Border>

                    <!-- Copyright Hinweis rechts unten -->
                        <TextBlock x:Name="MapCopyrightText"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,8,4"
                                   FontSize="10"
                                   Foreground="Gray"
                                   Background="#99FFFFFF"
                                   Padding="4,2"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   Text="© OpenStreetMap contributors"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Info Tab -->
            <TabItem Header="{DynamicResource StrTabInfo}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Meshhessen Client" FontSize="24" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="AboutVersionText" FontSize="16" Foreground="Gray" Margin="0,0,0,16"/>
                        <TextBlock Text="{DynamicResource StrAboutDescription}"
                                  TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <TextBlock Text="{DynamicResource StrLicensesTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="OpenStreetMap" FontWeight="Bold"/>
                                <TextBlock Text="{DynamicResource StrOsmData}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="Gray" FontSize="11">
                                    <Run Text="{DynamicResource StrLicense}"/><Run Text=": Open Data Commons Open Database License (ODbL)"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="Gray">
                                    <Hyperlink NavigateUri="https://www.openstreetmap.org/copyright" RequestNavigate="Hyperlink_RequestNavigate">
                                        <Run Text="openstreetmap.org/copyright"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="OpenTopoMap" FontWeight="Bold"/>
                                <TextBlock Text="{DynamicResource StrOsmTopoData}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="Gray" FontSize="11">
                                    <Run Text="{DynamicResource StrLicense}"/><Run Text=": CC-BY-SA"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="Gray">
                                    <Hyperlink NavigateUri="https://opentopomap.org/about" RequestNavigate="Hyperlink_RequestNavigate">
                                        <Run Text="opentopomap.org/about"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Meshtastic" FontWeight="Bold"/>
                                <TextBlock Text="{DynamicResource StrMeshtasticDesc}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="Gray" FontSize="11">
                                    <Run Text="{DynamicResource StrLicense}"/><Run Text=": GPL-3.0"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="Gray">
                                    <Hyperlink NavigateUri="https://meshtastic.org" RequestNavigate="Hyperlink_RequestNavigate">
                                        <Run Text="meshtastic.org"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Mapsui" FontWeight="Bold"/>
                                <TextBlock Text="{DynamicResource StrMapsuiDesc}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="Gray" FontSize="11">
                                    <Run Text="{DynamicResource StrLicense}"/><Run Text=": LGPL-3.0"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="Gray">
                                    <Hyperlink NavigateUri="https://mapsui.com" RequestNavigate="Hyperlink_RequestNavigate">
                                        <Run Text="mapsui.com"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="BruTile" FontWeight="Bold"/>
                                <TextBlock Text="{DynamicResource StrBruTileDesc}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="Gray" FontSize="11">
                                    <Run Text="{DynamicResource StrLicense}"/><Run Text=": Apache 2.0"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="ModernWPF" FontWeight="Bold"/>
                                <TextBlock Text="{DynamicResource StrModernWpfDesc}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="Gray" FontSize="11">
                                    <Run Text="{DynamicResource StrLicense}"/><Run Text=": MIT"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Google Protobuf" FontWeight="Bold"/>
                                <TextBlock Text="{DynamicResource StrProtobufDesc}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="Gray" FontSize="11">
                                    <Run Text="{DynamicResource StrLicense}"/><Run Text=": BSD-3-Clause"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Padding="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource StrProjectTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11">
                                    <Hyperlink NavigateUri="https://www.meshhessen.de" RequestNavigate="Hyperlink_RequestNavigate">
                                        <Run Text="www.meshhessen.de"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Debug Tab -->
            <TabItem Header="🐛 Debug">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Debug Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="ClearLogButton"
                               Content="{DynamicResource StrLogClear}"
                               Click="ClearLog_Click"
                               Margin="0,0,10,0"/>
                        <Button x:Name="CopyLogButton"
                               Content="{DynamicResource StrLogCopy}"
                               Click="CopyLog_Click"
                               Margin="0,0,10,0"/>
                        <Button x:Name="OpenLogFileButton"
                               Content="{DynamicResource StrLogFile}"
                               Click="OpenLogFile_Click"/>
                    </StackPanel>

                    <!-- Debug Log Output -->
                    <TextBox x:Name="DebugLogTextBox"
                            Grid.Row="1"
                            IsReadOnly="True"
                            FontFamily="Consolas"
                            FontSize="12"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto"
                            TextWrapping="NoWrap"
                            Background="{DynamicResource SystemControlBackgroundBaseBrush}"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusBarText"
                          Text="{DynamicResource StrReady}"
                          VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="PacketCountText"
                              Text="Pakete: 0"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource StrOwnNodeIdLabel}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="OwnNodeIdText" Margin="4,0,0,0" Text="-" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Update hint: shown when a newer release is detected -->
                    <Border x:Name="UpdateBanner" Visibility="Collapsed"
                            Background="#33FF8800" CornerRadius="3" Padding="6,2" Margin="0,0,12,0">
                        <TextBlock FontSize="11" VerticalAlignment="Center">
                            <Hyperlink x:Name="UpdateHintLink" RequestNavigate="UpdateHint_RequestNavigate">
                                <Run x:Name="UpdateHintRun"/>
                            </Hyperlink>
                        </TextBlock>
                    </Border>
                    <TextBlock x:Name="FooterVersionText" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,12,0" FontSize="11"/>
                    <Image Source="pack://application:,,,/Resources/app.ico" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center">
                        <Hyperlink NavigateUri="https://www.meshhessen.de" RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="www.meshhessen.de" FontWeight="Bold"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
