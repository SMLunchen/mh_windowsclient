<Window x:Class="MeshhessenClient.TracerouteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{DynamicResource StrTrTitle}"
        Width="560" Height="460"
        MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="🔍" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TargetNameText" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock x:Name="TargetIdText" FontSize="11" Opacity="0.6"/>
            </StackPanel>
        </StackPanel>

        <!-- Status bar -->
        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="4" Padding="8,5" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Text="{DynamicResource StrTrNoRequest}" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HopCountText" FontSize="11" Margin="0,0,8,0" Opacity="0.7"/>
                    <Border x:Name="MqttIndicator" Background="#FF8000" CornerRadius="3"
                            Padding="5,1" Visibility="Collapsed">
                        <TextBlock Text="via MQTT" FontSize="10" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Hop list (built programmatically in code-behind) -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="HopsPanel"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LastResultText" Grid.Column="0"
                       VerticalAlignment="Center" FontSize="11" Opacity="0.55"/>
            <Button x:Name="ClearMapButton" Grid.Column="1"
                    Content="{DynamicResource StrTrRemoveFromMap}"
                    Margin="0,0,8,0" Padding="10,6"
                    IsEnabled="False"
                    Click="ClearMapButton_Click"/>
            <Button x:Name="PlotOnMapButton" Grid.Column="2"
                    Content="{DynamicResource StrTrShowOnMap}"
                    Margin="0,0,8,0" Padding="10,6"
                    IsEnabled="False"
                    Click="PlotOnMapButton_Click"/>
            <Button x:Name="RequestButton" Grid.Column="3"
                    Content="{DynamicResource StrTrStart}"
                    Padding="10,6"
                    Click="RequestButton_Click"/>
        </Grid>
    </Grid>
</Window>
