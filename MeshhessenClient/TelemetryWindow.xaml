<Window x:Class="MeshhessenClient.TelemetryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{DynamicResource StrTelemetryWindowTitle}"
        Width="640" Height="580"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Opacity" Value="0.75"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Node info left, 2×2 LED Ampel right -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="📊" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="NodeNameText" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="NodeIdText" FontSize="11" Opacity="0.6"/>
                </StackPanel>
            </StackPanel>

            <!-- Node-Status Ampel (2×2): Signal / Energie / ACK / Kanal -->
            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,14,4">
                    <Ellipse x:Name="NodeSignalLed" Width="14" Height="14" Fill="#757575"
                             Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource StrTelSignal}" FontSize="10" Opacity="0.7" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,4">
                    <Ellipse x:Name="NodeBatteryLed" Width="14" Height="14" Fill="#757575"
                             Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource StrTelEnergy}" FontSize="10" Opacity="0.7" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,14,0">
                    <Ellipse x:Name="NodeAckLed" Width="14" Height="14" Fill="#757575"
                             Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource StrTelTrend}" FontSize="10" Opacity="0.7" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                    <Ellipse x:Name="NodeChanLed" Width="14" Height="14" Fill="#757575"
                             Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource StrTelChannel}" FontSize="10" Opacity="0.7" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Time range selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource StrTelTimeRange}" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.7" FontSize="12"/>
            <RadioButton x:Name="Range7d"  Content="{DynamicResource StrTel7d}"  GroupName="Range" IsChecked="True" Margin="0,0,8,0" Checked="OnRangeChanged"/>
            <RadioButton x:Name="Range14d" Content="{DynamicResource StrTel14d}" GroupName="Range" Margin="0,0,8,0" Checked="OnRangeChanged"/>
            <RadioButton x:Name="Range30d" Content="{DynamicResource StrTel30d}" GroupName="Range" Margin="0,0,8,0" Checked="OnRangeChanged"/>
            <RadioButton x:Name="RangeAll" Content="{DynamicResource StrTelAll}" GroupName="Range" Checked="OnRangeChanged"/>
            <TextBlock x:Name="DataCountText" FontSize="11" Opacity="0.5" VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="2" x:Name="MainTabs">

            <!-- ── Signal ── -->
            <TabItem Header="{DynamicResource StrTelTabSignal}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource StrTelSnrSection}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource StrTelDayLabel}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource StrTelNightLabel}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource StrTelSnrMedian}" Style="{StaticResource StatLabel}"
                                       ToolTip="Signal-to-Noise Ratio in dB. Higher = better reception quality. Typical: &gt;5 dB excellent, -10…5 dB normal, &lt;-10 dB weak."/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SnrDayMedian" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="SnrNightMedian" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource StrTelRssiMedian}" Style="{StaticResource StatLabel}"
                                       ToolTip="Received Signal Strength Indicator in dBm. Measures absolute signal strength at the receiver. Typical: &gt;-100 dBm good, -100…-115 dBm marginal, &lt;-115 dBm poor."/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RssiDayMedian" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="RssiNightMedian" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource StrTelSnrDelta}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtSnrDayNight}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SnrDelta" Style="{StaticResource StatValue}" HorizontalAlignment="Center" Grid.ColumnSpan="2"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource StrTelRssiDelta}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtRssiDayNight}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="RssiDelta" Style="{StaticResource StatValue}" HorizontalAlignment="Center" Grid.ColumnSpan="2"/>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource StrTelFullRange}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource StrTelSnrMinMax}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtSnrMinMax}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SnrMinMax" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource StrTelSnrVariance}" Style="{StaticResource StatLabel}"
                                       ToolTip="SNR variance indicates signal stability. Low variance = stable link. High variance = fluctuating signal quality."/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SnrVariance" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource StrTelRssiMinMax}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtRssiMinMax}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RssiMinMax" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource StrTelPacketsTotal}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtSnrPackets}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TotalPackets" Style="{StaticResource StatValue}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Power ── -->
            <TabItem Header="{DynamicResource StrTelTabPower}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource StrTelBatterySection}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource StrTelDayLabel}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource StrTelNightLabel}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource StrTelBatteryAvg}" Style="{StaticResource StatLabel}"
                                       ToolTip="Average battery charge level (%) during day/night hours. Day/night boundary determined by astronomical sunrise/sunset (NOAA algorithm)."/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="BatDayAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="BatNightAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource StrTelBatteryNight}" Style="{StaticResource StatLabel}"
                                       ToolTip="Night avg minus day avg of battery level. Negative = battery drops overnight (discharging without solar). Positive = battery rises (solar charging dominates)."/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BatNightDrop" Style="{StaticResource StatValue}" HorizontalAlignment="Center" Grid.ColumnSpan="2"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource StrTelVoltageAvg}" Style="{StaticResource StatLabel}"
                                       ToolTip="Average supply voltage in Volts during day/night hours."/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="VoltDayAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="VoltNightAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource StrTelVoltageNight}" Style="{StaticResource StatLabel}"
                                       ToolTip="Night avg minus day avg of voltage. Negative = voltage drops at night (discharging/darkness). Positive = voltage rises during day (solar feed-in)."/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="VoltNightDrop" Style="{StaticResource StatValue}" HorizontalAlignment="Center" Grid.ColumnSpan="2"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource StrTelVoltageMinMax}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtVoltageMinMax}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="VoltMinMax" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource StrTelUptime}" Style="{StaticResource StatLabel}"
                                       ToolTip="Device uptime since last reboot, from the most recent telemetry packet."/>
                            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="LastUptime" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource StrTelReadingsTotal}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtReadings}"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" x:Name="TelReadings" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Airtime ── -->
            <TabItem Header="{DynamicResource StrTelTabAirtime}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource StrTelChannelSection}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource StrTelDayLabel}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource StrTelNightLabel}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource StrTelChanUtilAvg}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtChanUtilAvg}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CuDayAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="CuNightAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource StrTelChanUtilMax}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtChanUtilMax}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CuMax" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource StrTelAirTxAvg}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtAirTxAvg}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="AuDayAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="AuNightAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource StrTelAirTxMax}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtAirTxMax}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="AuMax" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Routing ── -->
            <TabItem Header="{DynamicResource StrTelTabRouting}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource StrTelHopSection}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource StrTelHopsAvg}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtHopsAvg}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HopsStats" Style="{StaticResource StatValue}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource StrTelAckRate}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtAckRate}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AckRate" Style="{StaticResource StatValue}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource StrTelAckReqRcv}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtAckReq}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AckCounts" Style="{StaticResource StatValue}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource StrTelUniqueRelays}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtRelays}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="UniqueFrom" Style="{StaticResource StatValue}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource StrTelPacketsTotal}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtRoutingTotal}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="RoutingTotal" Style="{StaticResource StatValue}"/>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource StrTelHopDist}"/>
                        <TextBlock x:Name="HopDistText" FontSize="12" TextWrapping="Wrap" Opacity="0.85"/>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="{DynamicResource StrTelPathSection}" Margin="0,14,0,4"/>
                        <TextBlock FontSize="11" FontStyle="Italic" Opacity="0.55" TextWrapping="Wrap" Margin="0,0,0,6"
                                   Text="{DynamicResource StrTtTracerouteOnly}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource StrTelHopCost}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtHopCost}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HopCostText" Style="{StaticResource StatValue}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource StrTelRouteChanges}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtRouteChangeRate}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RouteChangeRateText" Style="{StaticResource StatValue}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource StrTelTracerouteSamples}" Style="{StaticResource StatLabel}"
                                       ToolTip="{DynamicResource StrTtTracerouteSamples}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TracerouteCountText" Style="{StaticResource StatValue}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Neighbors ── -->
            <TabItem Header="{DynamicResource StrTelNeighbors}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Margin="8,8,8,4" FontSize="11" FontStyle="Italic" Opacity="0.6"
                               TextWrapping="Wrap"
                               Text="{DynamicResource StrTtNeighborSection}"/>
                    <DataGrid Grid.Row="1" x:Name="NeighborGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Margin="4"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Node" Binding="{Binding NeighborName}" Width="150"/>
                            <DataGridTextColumn Header="Median SNR" Binding="{Binding MedianSnrDisplay}" Width="90"/>
                            <DataGridTextColumn Header="Median RSSI" Binding="{Binding MedianRssiDisplay}" Width="95"/>
                            <DataGridTextColumn Header="Pkts/h" Binding="{Binding PacketsPerHourDisplay}" Width="60"/>
                            <DataGridTextColumn Header="Trend" Binding="{Binding TrendArrow}"
                                                Width="55"
                                                ElementStyle="{StaticResource StatValue}"/>
                            <DataGridTextColumn Header="{DynamicResource StrTelLastSeen}" Binding="{Binding LastSeenDisplay}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer buttons -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FooterInfoText" Grid.Column="0"
                       VerticalAlignment="Center" FontSize="11" Opacity="0.5"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{DynamicResource StrTelOpenDashboard}"
                        Padding="12,6" Margin="0,0,8,0" Click="OpenDashboard_Click"/>
                <Button Content="{DynamicResource StrTelOpenPlot}"
                        Padding="12,6" Click="OpenPlotWindow_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
