<Window x:Class="MeshhessenClient.TelemetryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Telemetrie"
        Width="640" Height="560"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Opacity" Value="0.75"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="📊" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="NodeNameText" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock x:Name="NodeIdText" FontSize="11" Opacity="0.6"/>
            </StackPanel>
        </StackPanel>

        <!-- Time range selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Zeitraum:" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.7" FontSize="12"/>
            <RadioButton x:Name="Range7d"  Content="7 Tage"   GroupName="Range" IsChecked="True" Margin="0,0,8,0" Checked="OnRangeChanged"/>
            <RadioButton x:Name="Range14d" Content="14 Tage"  GroupName="Range" Margin="0,0,8,0" Checked="OnRangeChanged"/>
            <RadioButton x:Name="Range30d" Content="30 Tage"  GroupName="Range" Margin="0,0,8,0" Checked="OnRangeChanged"/>
            <RadioButton x:Name="RangeAll" Content="Gesamt"   GroupName="Range" Checked="OnRangeChanged"/>
            <TextBlock x:Name="DataCountText" FontSize="11" Opacity="0.5" VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="2" x:Name="MainTabs">

            <!-- ── Signal ── -->
            <TabItem Header="📶 Signal">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="SNR (Empfangsqualität)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <!-- Headers -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Tag" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Nacht" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <!-- SNR -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SNR Median" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SnrDayMedian" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="SnrNightMedian" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <!-- RSSI -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="RSSI Median" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RssiDayMedian" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="RssiNightMedian" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Gesamtbereich"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="SNR Min / Max" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SnrMinMax" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SNR Varianz" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SnrVariance" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="RSSI Min / Max" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RssiMinMax" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Pakete gesamt" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TotalPackets" Style="{StaticResource StatValue}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Power ── -->
            <TabItem Header="🔋 Energie">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Batterie &amp; Spannung"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Tag" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Nacht" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Batterie Ø" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="BatDayAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="BatNightAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Batterie Nacht-Abfall" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BatNightDrop" Style="{StaticResource StatValue}" HorizontalAlignment="Center" Grid.ColumnSpan="2"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Spannung Ø" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="VoltDayAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="VoltNightAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Spannung Nacht-Abfall" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="VoltNightDrop" Style="{StaticResource StatValue}" HorizontalAlignment="Center" Grid.ColumnSpan="2"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Spannung Min / Max" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="VoltMinMax" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Uptime (zuletzt)" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="LastUptime" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Messwerte gesamt" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" x:Name="TelReadings" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Airtime ── -->
            <TabItem Header="📡 Airtime">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Kanalauslastung"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Tag" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Nacht" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Channel Util Ø" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CuDayAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="CuNightAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Channel Util Max" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CuMax" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Air TX Util Ø" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="AuDayAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="AuNightAvg" Style="{StaticResource StatValue}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Air TX Util Max" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="AuMax" Style="{StaticResource StatValue}" Grid.ColumnSpan="2"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Routing ── -->
            <TabItem Header="🔀 Routing">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel Margin="8">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Hop-Analyse"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Hops Ø / Min / Max" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HopsStats" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ACK-Erfolgsrate" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AckRate" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="ACK angefordert / erhalten" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AckCounts" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Unique Relay-Nodes" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="UniqueFrom" Style="{StaticResource StatValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Pakete gesamt" Style="{StaticResource StatLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="RoutingTotal" Style="{StaticResource StatValue}"/>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Hop-Verteilung"/>
                        <TextBlock x:Name="HopDistText" FontSize="12" TextWrapping="Wrap" Opacity="0.85"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Neighbors ── -->
            <TabItem Header="🔗 Nachbarn">
                <DataGrid x:Name="NeighborGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Margin="4"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Node" Binding="{Binding NeighborName}" Width="160"/>
                        <DataGridTextColumn Header="Median SNR" Binding="{Binding MedianSnrDisplay}" Width="90"/>
                        <DataGridTextColumn Header="Median RSSI" Binding="{Binding MedianRssiDisplay}" Width="95"/>
                        <DataGridTextColumn Header="Pkts/h" Binding="{Binding PacketsPerHourDisplay}" Width="70"/>
                        <DataGridTextColumn Header="Letzte Sichtung" Binding="{Binding LastSeenDisplay}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>

        <!-- Footer buttons -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FooterInfoText" Grid.Column="0"
                       VerticalAlignment="Center" FontSize="11" Opacity="0.5"/>
            <Button Grid.Column="1" Content="📈 Im Plot öffnen"
                    Padding="12,6" Click="OpenPlotWindow_Click"/>
        </Grid>
    </Grid>
</Window>
